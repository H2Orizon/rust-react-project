{
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev:web": "concurrently \"npm run backend\" \"npm run frontend\"",
    "dev:mob":"concurrently \"npm run backend\" \"npm run mobile\"",
    "dev:all":"concurrently \"npm run backend\" \"npm run frontend\" \"npm run mobile\"",
    "backend": "cd backend && cargo run",
    "frontend": "cd frontend && npm run dev",
    "mobile": "cd mobile && npm start",
    "migration-refresh": "cd backend/database/migration && cargo run -- fresh"
  },
  "dependencies": {
    "axios": "^1.15.2"
  },
  "workspaces": [
    "frontend",
    "mobile",
    "shared"
  ]
}
